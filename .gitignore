*.spec

# AUDIO SORGENTE PESANTE

# Nel sito devono restare solo gli audio finali ottimizzati, per esempio MP3 leggeri.

# WAV e FLAC sono sorgenti di lavoro, non asset da caricare nel repository.

public/audio/*.wav
public/audio/*.flac

# VIDEO SORGENTE PESANTE

# Lasciare nel repository solo MP4 ottimizzati per il web.

# I formati sorgente o intermedi vanno tenuti fuori da Git.

public/**/*.mov
public/**/*.avi
public/**/*.mkv
public/**/*.wmv
public/**/*.flv

# TOOL DI OTTIMIZZAZIONE IMMAGINI

# picture_update è la cartella di ingresso per immagini e video grezzi.

# picture è la cartella finale usata dal sito.

# picture_optimized e picture_originale_non_ottimizzata sono cartelle di lavoro o backup locale.

# I file original e tmp sono copie temporanee o di sicurezza create durante le prove con Sharp.

public/picture_update/
public/picture_optimized/
public/picture_originale_non_ottimizzata/
public/picture/**/*-original.*
public/picture/**/*.tmp.webp

# FILE TEMPORANEI DI BACKUP CREATI DA EDITOR O SISTEMA

*.bak
*.tmp
*.temp
~$*
node_modules
dist
dist-ssr
.vscode
